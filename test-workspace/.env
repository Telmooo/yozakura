# Yozakura - .env example
# These files are all gibberish, do not attempt to run them

#  Application
APP_NAME=yozakura
APP_VERSION=1.0.0
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:8080
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_SECRET_KEY=super-secret-key-change-in-production
APP_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

#  Node.js
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

#  Database
DATABASE_URL=postgresql://app_user:secret_password@localhost:5432/yozakura_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=yozakura_db
DATABASE_USER=app_user
DATABASE_PASSWORD=secret_password
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_CONNECT_TIMEOUT=5000
DATABASE_SCHEMA=public
DATABASE_MIGRATION_DIR=./migrations

# Read replica
DATABASE_READ_URL=postgresql://readonly:read_pass@localhost:5433/yozakura_db

#  Redis / Cache
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=yoza:
REDIS_DEFAULT_TTL=3600

#  Authentication
JWT_SECRET=your-256-bit-secret-key-here-change-this-in-prod
JWT_ISSUER=yozakura
JWT_AUDIENCE=yozakura-api
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

COOKIE_SECRET=another-secret-key-for-cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=localhost
SESSION_TTL=86400

# OAuth providers
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=Iv1.abcdef1234567890
GITHUB_CLIENT_SECRET=abcdef1234567890abcdef1234567890abcdef12
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

#  Cloud Storage
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=yozakura-assets-dev
AWS_S3_ENDPOINT=
AWS_CLOUDFRONT_URL=

# MinIO (local S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=yozakura
MINIO_USE_SSL=false

#  Email
SMTP_HOST=smtp.mailhog.local
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yozakura.dev
SMTP_FROM_NAME=Yozakura
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_REJECT_UNAUTHORIZED=false

#  Monitoring & Observability
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=1.0

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=yozakura
OTEL_SERVICE_VERSION=1.0.0
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

GRAFANA_URL=http://localhost:3001
GRAFANA_API_KEY=glsa_exampleGrafanaApiKey123

#  Feature Flags
FEATURE_DARK_MODE=true
FEATURE_BETA_EDITOR=false
FEATURE_ANALYTICS=false
FEATURE_NOTIFICATIONS=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_TWO_FACTOR_AUTH=false

#  External APIs
STRIPE_PUBLIC_KEY=pk_test_51ExampleStripePublicKeyHere
STRIPE_SECRET_KEY=sk_test_51ExampleStripeSecretKeyHere
STRIPE_WEBHOOK_SECRET=whsec_exampleWebhookSecretHere

OPENAI_API_KEY=sk-proj-exampleOpenAIKeyHere
OPENAI_ORG_ID=org-exampleOrgId
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-exampleAnthropicKeyHere

GITHUB_TOKEN=ghp_examplePersonalAccessTokenHere
GITHUB_WEBHOOK_SECRET=example-webhook-secret

#  Internal Services
AUTH_SERVICE_URL=http://localhost:4001
AUTH_SERVICE_API_KEY=internal-auth-service-key

NOTIFICATION_SERVICE_URL=http://localhost:4002
NOTIFICATION_SERVICE_API_KEY=internal-notification-key

SEARCH_SERVICE_URL=http://localhost:9200
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=yozakura

#  Build & Deployment
CI=false
BUILD_ID=local
GIT_COMMIT=
GIT_BRANCH=main
DEPLOY_ENV=development
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE=telmooo/yozakura

#  Timeouts & Limits (ms)
HTTP_TIMEOUT=30000
HTTP_RETRY_COUNT=3
HTTP_RETRY_DELAY=1000
UPLOAD_MAX_SIZE=10485760
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
