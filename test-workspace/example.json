        "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
        "headers": ["Content-Type", "Authorization"],
        "credentials": true,
        "maxAge": 86400
      }
    },
    "database": {
      "driver": "postgres",
      "host": "localhost",
      "port": 5432,
      "name": "yozakura_db",
      "pool": {
        "min": 2,
        "max": 10,
        "idleTimeoutMs": 30000,
        "connectionTimeoutMs": 5000
      },
      "ssl": {
        "enabled": false,
        "rejectUnauthorized": true,
        "cert": null
      }
    },
    "cache": {
      "driver": "redis",
      "ttl": 3600,
      "keyPrefix": "yoza:",
      "compression": true
    },
    "logging": {
      "level": "info",
      "format": "json",
      "outputs": ["stdout", "file"],
      "file": {
        "path": "/var/log/yozakura/app.log",
        "maxSize": "100MB",
        "maxFiles": 5,
        "compress": true
      }
    }
  },
  "features": [
    {
      "id": "syntax-highlighting",
      "name": "Syntax Highlighting",
