{
  "$schema": "vscode://schemas/color-theme",
  "name": "Yozakura",
  "type": "dark",
  "colors": {
    // Backgrounds
    "editor.background": "#160f1e",
    "editor.foreground": "#e0d4e8",
    "sideBar.background": "#130c1a",
    "sideBar.foreground": "#b0a4be",
    "sideBar.border": "#2a1f36",
    "sideBarTitle.foreground": "#e0d4e8",
    "sideBarSectionHeader.background": "#1a1224",
    "sideBarSectionHeader.foreground": "#c8bcd6",
    "activityBar.background": "#0f0a14",
    "activityBar.foreground": "#fdb8ff",
    "activityBar.inactiveForeground": "#6b5f7b",
    "activityBarBadge.background": "#fdb8ff",
    "activityBarBadge.foreground": "#160f1e",
    "panel.background": "#130c1a",
    "panel.border": "#2a1f36",
    "panelTitle.activeBorder": "#fdb8ff",
    "panelTitle.activeForeground": "#e0d4e8",
    "panelTitle.inactiveForeground": "#6b5f7b",
    "statusBar.background": "#0f0a14",
    "statusBar.foreground": "#b0a4be",
    "statusBar.debuggingBackground": "#fdb8ff",
    "statusBar.debuggingForeground": "#160f1e",
    "statusBar.noFolderBackground": "#1a1224",
    "statusBar.noFolderForeground": "#b0a4be",
    "titleBar.activeBackground": "#0f0a14",
    "titleBar.activeForeground": "#e0d4e8",
    "titleBar.inactiveBackground": "#0f0a14",
    "titleBar.inactiveForeground": "#6b5f7b",

    // Tabs
    "tab.activeBackground": "#160f1e",
    "tab.activeForeground": "#e0d4e8",
    "tab.activeBorderTop": "#fdb8ff",
    "tab.inactiveBackground": "#110b18",
    "tab.inactiveForeground": "#6b5f7b",
    "tab.border": "#0f0a14",
    "editorGroupHeader.tabsBackground": "#110b18",

    // Editor UI
    "editor.lineHighlightBackground": "#1e152808",
    "editor.lineHighlightBorder": "#2a1f3640",
    "editor.selectionBackground": "#fdb8ff28",
    "editor.selectionHighlightBackground": "#fdb8ff15",
    "editor.wordHighlightBackground": "#fdb8ff18",
    "editor.wordHighlightStrongBackground": "#fdb8ff25",
    "editor.findMatchBackground": "#fdb8ff35",
    "editor.findMatchHighlightBackground": "#fdb8ff18",
    "editorCursor.foreground": "#fdb8ff",
    "editorWhitespace.foreground": "#2a1f36",
    "editorIndentGuide.background1": "#2a1f36",
    "editorIndentGuide.activeBackground1": "#3d2f50",
    "editorLineNumber.foreground": "#3d2f50",
    "editorLineNumber.activeForeground": "#8b7f99",
    "editorBracketMatch.background": "#fdb8ff18",
    "editorBracketMatch.border": "#fdb8ff60",
    "editorRuler.foreground": "#2a1f36",
    "editorOverviewRuler.border": "#2a1f36",
    "editorGutter.addedBackground": "#88c088",
    "editorGutter.modifiedBackground": "#e8b040",
    "editorGutter.deletedBackground": "#f05070",

    // Bracket Pair Colorization
    "editorBracketHighlight.foreground1": "#fdb8ff",
    "editorBracketHighlight.foreground2": "#c4a0f0",
    "editorBracketHighlight.foreground3": "#8cc8e8",
    "editorBracketHighlight.foreground4": "#f0c4a8",
    "editorBracketHighlight.foreground5": "#a8d0c0",
    "editorBracketHighlight.foreground6": "#e8a8c0",

    // Widgets & Dropdowns
    "editorWidget.background": "#1a1224",
    "editorWidget.foreground": "#e0d4e8",
    "editorWidget.border": "#2a1f36",
    "editorSuggestWidget.background": "#1a1224",
    "editorSuggestWidget.border": "#2a1f36",
    "editorSuggestWidget.selectedBackground": "#fdb8ff20",
    "editorSuggestWidget.highlightForeground": "#fdb8ff",
    "editorHoverWidget.background": "#1a1224",
    "editorHoverWidget.border": "#2a1f36",
    "dropdown.background": "#1e1528",
    "dropdown.border": "#2a1f36",
    "dropdown.foreground": "#e0d4e8",
    "input.background": "#1e1528",
    "input.border": "#2a1f36",
    "input.foreground": "#e0d4e8",
    "input.placeholderForeground": "#5e4f72",
    "inputOption.activeBorder": "#fdb8ff",
    "inputOption.activeBackground": "#fdb8ff20",
    "inputValidation.errorBackground": "#f0507020",
    "inputValidation.errorBorder": "#f05070",
    "inputValidation.warningBackground": "#e8b04020",
    "inputValidation.warningBorder": "#e8b040",

    // Lists & Trees
    "list.activeSelectionBackground": "#fdb8ff20",
    "list.activeSelectionForeground": "#e0d4e8",
    "list.hoverBackground": "#fdb8ff10",
    "list.inactiveSelectionBackground": "#fdb8ff12",
    "list.highlightForeground": "#fdb8ff",
    "list.focusOutline": "#fdb8ff60",

    // Command Palette
    "quickInput.background": "#1a1224",
    "quickInput.foreground": "#e0d4e8",
    "quickInputList.focusBackground": "#fdb8ff20",
    "quickInputList.focusForeground": "#e0d4e8",

    // Scrollbar
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#fdb8ff15",
    "scrollbarSlider.hoverBackground": "#fdb8ff25",
    "scrollbarSlider.activeBackground": "#fdb8ff35",

    // Minimap
    "minimap.selectionHighlight": "#fdb8ff40",
    "minimap.findMatchHighlight": "#fdb8ff50",

    // Peek View
    "peekView.border": "#fdb8ff60",
    "peekViewEditor.background": "#1a1224",
    "peekViewResult.background": "#130c1a",
    "peekViewTitle.background": "#1a1224",
    "peekViewTitleLabel.foreground": "#e0d4e8",
    "peekViewTitleDescription.foreground": "#8b7f99",
    "peekViewResult.selectionBackground": "#fdb8ff20",
    "peekViewEditor.matchHighlightBackground": "#fdb8ff30",
    "peekViewResult.matchHighlightBackground": "#fdb8ff30",

    // Diff Editor
    "diffEditor.insertedTextBackground": "#88c08818",
    "diffEditor.removedTextBackground": "#f0507018",

    // Merge Conflict
    "merge.currentHeaderBackground": "#88c08840",
    "merge.incomingHeaderBackground": "#8cc8e840",

    // Notifications
    "notificationCenter.border": "#2a1f36",
    "notifications.background": "#1a1224",
    "notifications.foreground": "#e0d4e8",
    "notifications.border": "#2a1f36",

    // Terminal
    "terminal.background": "#130c1a",
    "terminal.foreground": "#e0d4e8",
    "terminal.ansiBlack": "#1a1224",
    "terminal.ansiRed": "#f05070",
    "terminal.ansiGreen": "#88c088",
    "terminal.ansiYellow": "#e8b040",
    "terminal.ansiBlue": "#8cc8e8",
    "terminal.ansiMagenta": "#fdb8ff",
    "terminal.ansiCyan": "#a8d0c0",
    "terminal.ansiWhite": "#e0d4e8",
    "terminal.ansiBrightBlack": "#5e4f72",
    "terminal.ansiBrightRed": "#f57090",
    "terminal.ansiBrightGreen": "#a8d8a8",
    "terminal.ansiBrightYellow": "#f0c860",
    "terminal.ansiBrightBlue": "#a8d8f0",
    "terminal.ansiBrightMagenta": "#ffd0ff",
    "terminal.ansiBrightCyan": "#c0e8d8",
    "terminal.ansiBrightWhite": "#f5eef8",
    "terminalCursor.foreground": "#fdb8ff",

    // Git Decorations
    "gitDecoration.addedResourceForeground": "#88c088",
    "gitDecoration.modifiedResourceForeground": "#e8b040",
    "gitDecoration.deletedResourceForeground": "#f05070",
    "gitDecoration.untrackedResourceForeground": "#a8d0c0",
    "gitDecoration.conflictingResourceForeground": "#f0c4a8",
    "gitDecoration.ignoredResourceForeground": "#3d2f50",

    // Errors & Warnings
    "errorForeground": "#f05070",
    "editorError.foreground": "#f05070",
    "editorWarning.foreground": "#e8b040",
    "editorInfo.foreground": "#8cc8e8",

    // Buttons
    "button.background": "#fdb8ff",
    "button.foreground": "#160f1e",
    "button.hoverBackground": "#ffd0ff",
    "button.secondaryBackground": "#2a1f36",
    "button.secondaryForeground": "#e0d4e8",
    "button.secondaryHoverBackground": "#3d2f50",

    // Badge
    "badge.background": "#fdb8ff",
    "badge.foreground": "#160f1e",

    // Breadcrumbs
    "breadcrumb.foreground": "#8b7f99",
    "breadcrumb.focusForeground": "#e0d4e8",
    "breadcrumb.activeSelectionForeground": "#fdb8ff",

    // Focus & Borders
    "focusBorder": "#fdb8ff60",
    "foreground": "#e0d4e8",
    "widget.shadow": "#00000030",
    "selection.background": "#fdb8ff30",
    "descriptionForeground": "#8b7f99",
    "icon.foreground": "#b0a4be"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5e4f72"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#f05070"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e8b040",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Keyword, Storage, Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#fdb8ff"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#9b8fad"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#8b7f99"
      }
    },
    {
      "name": "Function, Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#c4a0f0"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e8a8c0"
      }
    },
    {
      "name": "Constant, Booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#f0a0c0"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#f0c4a8"
      }
    },
    {
      "name": "String Escape Character",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#f0a0c0"
      }
    },
    {
      "name": "Type, Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "Interfaces, Type Parameters",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.type-parameter"
      ],
      "settings": {
        "foreground": "#8cc8e8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0d4e8"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#c8b8d8"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#d0b8e0"
      }
    },
    {
      "name": "Object Keys",
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#d0b8e0"
      }
    },
    {
      "name": "HTML/JSX - Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#fdb8ff"
      }
    },
    {
      "name": "HTML/JSX - Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c4a0f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS - Properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#d0b8e0"
      }
    },
    {
      "name": "CSS - Values, Units",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#e8a8c0"
      }
    },
    {
      "name": "CSS - Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "Decorators, Annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "meta.annotation"],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "Builtins, Support",
      "scope": [
        "support.variable",
        "support.constant",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#a8d0c0"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": {
        "foreground": "#e8a8c0"
      }
    },
    {
      "name": "Markdown - Headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": {
        "foreground": "#fdb8ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#f0c4a8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#c4a0f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown - Code Blocks",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#a8d0c0"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "JSON - Keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#c4a0f0"
      }
    },
    {
      "name": "YAML - Keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#c4a0f0"
      }
    },
    {
      "name": "Rust - Numbers",
      "scope": ["entity.name.type.numeric.rust"],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "Rust - References",
      "scope": [
        "keyword.operator.borrow.rust",
        "keyword.operator.dereference.rust"
      ],
      "settings": {
        "foreground": "#fdb8ff"
      }
    },
    {
      "name": "Rust - Lifetimes",
      "scope": ["entity.name.lifetime.rust"],
      "settings": {
        "foreground": "#f0a0c0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust - Namespace Operator",
      "scope": ["keyword.operator.namespace.rust", "keyword.operator.path"],
      "settings": {
        "foreground": "#8b7f99"
      }
    },
    {
      "name": "Rust - Macros",
      "scope": ["entity.name.type.macro.rust", "entity.name.function.macro"],
      "settings": {
        "foreground": "#a8d0c0"
      }
    },
    {
      "name": "Python - Docstrings",
      "scope": ["string.quoted.docstring"],
      "settings": {
        "foreground": "#5e4f72",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python - Types, Builtins",
      "scope": ["support.type.python", "support.function.builtin.python"],
      "settings": {
        "foreground": "#a8d0c0"
      }
    },
    {
      "name": "Python - Constants",
      "scope": ["constant.other.caps.python"],
      "settings": {
        "foreground": "#f0a0c0"
      }
    },

    // TypeScript-specific
    {
      "name": "Typescript - Types",
      "scope": [
        "keyword.operator.type.typescript",
        "keyword.operator.type.annotation"
      ],
      "settings": {
        "foreground": "#fdb8ff"
      }
    },
    {
      "name": "Typescript - Enums",
      "scope": ["entity.name.type.enum"],
      "settings": {
        "foreground": "#8cc8e8"
      }
    },
    {
      "name": "Typescript - Enum Members",
      "scope": ["variable.other.enummember"],
      "settings": {
        "foreground": "#f0a0c0"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#c4a0f0",
    "function.declaration": "#c4a0f0",
    "method": "#c4a0f0",
    "method.declaration": "#c4a0f0",
    "variable": "#e0d4e8",
    "variable.readonly": "#f0a0c0",
    "parameter": "#c8b8d8",
    "property": "#d0b8e0",
    "property.readonly": "#f0a0c0",
    "type": "#8cc8e8",
    "class": "#8cc8e8",
    "interface": { "foreground": "#8cc8e8", "fontStyle": "italic" },
    "enum": "#8cc8e8",
    "enumMember": "#f0a0c0",
    "namespace": "#d0b8e0",
    "typeParameter": { "foreground": "#8cc8e8", "fontStyle": "italic" },
    "decorator": "#8cc8e8",
    "macro": "#a8d0c0"
  }
}
